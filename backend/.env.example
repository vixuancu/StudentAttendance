# Database (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:YOUR-PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Connection Pool (giảm cho Supabase free tier)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_POOL_TIMEOUT=30

# App Settings
APP_NAME=StudentAttendance
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:3001","http://localhost:5173"]
